{
  "id": "delete-by-label-basics",
  "title": "Masowe usuwanie zasobów po etykiecie",
  "category": "Core Concepts",
  "difficulty": "Easy",
  "type": "task",
  "weight": 3,
  "description": "## Masowe usuwanie po etykiecie\n\nMożesz używać selektorów etykiet (`-l`) do wykonywania operacji masowych na zasobach.\n\n**Twoje zadanie:**\n\nW przestrzeni nazw default działa 5 podów. Usuń **tylko** pody z etykietą `env=dev`. Pozostaw działające pody `env=prod`.\n\n```bash\n# Weryfikacja które pody pozostały:\nkubectl get pods --show-labels\n```",
  "hints": [
    {
      "title": "Usuwanie z selektorem",
      "body": "Użyj `kubectl delete pods` z flagą `-l`.",
      "command": "kubectl delete pods -l env=dev"
    }
  ],
  "setup_commands": [
    {
      "command": "kubectl run dev-1 --image=nginx:alpine -l env=dev"
    },
    {
      "command": "kubectl run dev-2 --image=nginx:alpine -l env=dev"
    },
    {
      "command": "kubectl run dev-3 --image=nginx:alpine -l env=dev"
    },
    {
      "command": "kubectl run prod-1 --image=nginx:alpine -l env=prod"
    },
    {
      "command": "kubectl run prod-2 --image=nginx:alpine -l env=prod"
    }
  ],
  "validation": {
    "commands": [
      {
        "description": "Brak podów 'env=dev'",
        "command": "kubectl get pods -l env=dev --no-headers 2>/dev/null | wc -l | tr -d ' '",
        "expected_output": "0",
        "match": "exact"
      },
      {
        "description": "Pody prod nadal działają",
        "command": "kubectl get pods -l env=prod --no-headers 2>/dev/null | wc -l | tr -d ' '",
        "expected_output": "2",
        "match": "exact"
      }
    ]
  },
  "default_namespace": "default",
  "teardown_commands": [
    {
      "command": "kubectl delete pods -l env=dev --ignore-not-found --grace-period=0 --force"
    },
    {
      "command": "kubectl delete pods -l env=prod --ignore-not-found --grace-period=0 --force"
    }
  ]
}